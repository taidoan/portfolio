{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "docs": "concurrently \"npm run docs-ts\" \"npm run docs-sass\"",
    "docs-ts": "typedoc",
    "docs-sass": "sassdoc src/",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint-staged": "lint-staged",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "prepare": "husky",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,css,md}": "prettier --write"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.54.0",
    "@payloadcms/email-nodemailer": "^3.54.0",
    "@payloadcms/email-resend": "^3.54.0",
    "@payloadcms/live-preview-react": "^3.54.0",
    "@payloadcms/next": "^3.54.0",
    "@payloadcms/payload-cloud": "^3.54.0",
    "@payloadcms/plugin-form-builder": "^3.54.0",
    "@payloadcms/plugin-redirects": "^3.54.0",
    "@payloadcms/plugin-search": "^3.54.0",
    "@payloadcms/plugin-seo": "^3.54.0",
    "@payloadcms/richtext-lexical": "^3.54.0",
    "@payloadcms/storage-s3": "^3.54.0",
    "@storybook/addon-a11y": "^9.1.3",
    "@tabler/icons-react": "^3.30.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/qs": "^6.9.18",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "embla-carousel-auto-height": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.8.1",
    "motion": "^12.4.10",
    "next": "^15.3.2",
    "next-sitemap": "^4.2.3",
    "next-turnstile": "^1.0.2",
    "payload": "^3.54.0",
    "qs": "^6.14.0",
    "react": "19.0.0",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.55.0",
    "react-share": "^5.2.2",
    "react-zoom-pan-pinch": "^3.7.0",
    "sharp": "0.32.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@eslint/eslintrc": "^3.2.0",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-vitest": "9.1.3",
    "@storybook/nextjs-vite": "^9.1.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.18.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.0.7",
    "@vitest/coverage-v8": "^3.0.7",
    "concurrently": "^9.1.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.1.5",
    "eslint-plugin-storybook": "^9.1.3",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "playwright": "^1.50.1",
    "postcss": "^8.5.3",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^10.1.5",
    "postcss-sort-media-queries": "^5.2.0",
    "prettier": "^3.4.2",
    "sass": "^1.85.1",
    "sass-embedded": "^1.85.1",
    "sassdoc": "^2.7.4",
    "sassdoc-theme-herman": "^6.0.2",
    "storybook": "^9.1.3",
    "storybook-addon-pseudo-states": "^9.1.3",
    "typedoc": "^0.27.9",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}

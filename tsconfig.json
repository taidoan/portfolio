{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@config": ["./config"],
      "@scripts/*": ["./scripts/*"],
      "@payload-config": ["./src/payload.config.ts"],
      "@access": ["./src/payload/access"],
      "@fields/*": ["./src/payload/fields/*"],
      "@utilities/*": ["./src/lib/utilities/*"],
      "@components/*": ["./src/components/*"],
      "@collections/*": ["./src/payload/collections/*"],
      "@globals/*": ["./src/payload/globals/*"],
      "@hooks/*": ["./src/lib/hooks/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@styles/*": ["./src/styles/*"],
      "@abstracts/*": ["./src/styles/abstracts/*"],
      "@editor/*": ["./src/lib/editor/*"],
      "@blocks/*": ["./src/payload/blocks/*"],
      "@mocks/*": ["./src/mocks/*"]
    },
    "target": "ES2022",
    "types": ["vitest/globals"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}

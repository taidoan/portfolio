{
  "entryPoints": ["src"],
  "out": "./docs/ts",
  "tsconfig": "./tsconfig.json",
  "entryPointStrategy": "expand",
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/.storybook/**",
    "**/docs/**",
    "**/*.test.{ts,tsx,js,jsx}",
    "**/__tests__/**",
    "**/*.stories.{ts,tsx,js,jsx}",
    "**/(payload)/**/*"
  ]
}
